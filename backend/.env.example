# Copy to .env and fill in. Do not commit real secrets.

ENVIRONMENT=development

# Gemini (optional for this auth work)
# GEMINI_API_KEY=

# Firebase Admin — use either a file path OR inline JSON (containers), not both
# FIREBASE_CREDENTIALS_PATH=/absolute/path/to/serviceAccountKey.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Same Web API key as the Firebase console / client config (for Secure Token refresh)
FIREBASE_WEB_API_KEY=

# Cookie / session tuning (optional)
# ACCESS_COOKIE_NAME=fb_access
# REFRESH_COOKIE_NAME=fb_refresh
# ACCESS_SESSION_TTL_SECONDS=3600
# REFRESH_COOKIE_MAX_AGE_SECONDS=1209600
# COOKIE_SAMESITE=lax
# CORS_ORIGINS=http://localhost:5173
